    },
    "modelDownload.skipWarning" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Without downloading, this focus session uses rule-based evaluation, which may be less accurate than the local model." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "暂不下载时，本次专注会使用基础规则判断，准确性可能低于本地模型。" } }
