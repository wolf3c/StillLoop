    "modelDownload.setupMessage" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "StillLoop can download its built-in model for more precise local focus evaluation. It needs your confirmation before downloading." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "StillLoop 可以下载应用自带模型，在本机完成更细致的专注判断。下载开始前需要你的确认。" } }
